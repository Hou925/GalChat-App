<view class="chat-container"><view class="chat-header"><text class="header-title">张三AI</text></view><scroll-view class="chat-messages" scroll-y="true" scroll-top="{{b}}" scroll-with-animation="{{true}}" bindscrolltoupper="{{c}}"><view class="message-list"><view wx:for="{{a}}" wx:for-item="item" wx:key="d" class="{{['message-item', item.e]}}"><image class="avatar" src="{{item.a}}" mode="aspectFill"></image><view class="message-box"><view class="sender-box"><text class="sender-text">{{item.b}}</text></view><view class="message-content"><text class="message-text">{{item.c}}</text></view></view></view></view></scroll-view><view class="chat-footer"><view class="input-box"><input type="text" confirm-type="send" bindconfirm="{{d}}" placeholder="请输入消息" class="message-input" value="{{e}}" bindinput="{{f}}"/><button class="{{['send-btn', g && 'active']}}" bindtap="{{h}}">发送</button></view></view></view>