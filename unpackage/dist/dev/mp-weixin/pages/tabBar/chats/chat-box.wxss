/* 水平间距 */
.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f5f5;
}
.chat-container .chat-header {
  height: 88rpx;
  background-color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 30rpx;
  border-bottom: 1rpx solid #eaeaea;
}
.chat-container .chat-header .header-title {
  font-size: 32rpx;
  font-weight: bold;
}
.chat-container .chat-messages {
  flex: 1;
  padding: 20rpx;
}
.chat-container .chat-messages .message-list .message-item {
  display: flex;
  margin-bottom: 30rpx;
}
.chat-container .chat-messages .message-list .message-item .avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}
.chat-container .chat-messages .message-list .message-item .message-content {
  max-width: 60%;
  margin: 0 20rpx;
  background-color: #ffffff;
  border-radius: 10rpx;
  padding: 20rpx;
}
.chat-container .chat-messages .message-list .message-item .message-content .message-text {
  font-size: 28rpx;
  line-height: 1.5;
}
.chat-container .chat-messages .message-list .message-left .message-content {
  background-color: #ffffff;
}
.chat-container .chat-messages .message-list .message-right {
  flex-direction: row-reverse;
}
.chat-container .chat-messages .message-list .message-right .message-content {
  background-color: #95ec69;
}
.chat-container .chat-footer {
  background-color: #ffffff;
  padding: 20rpx;
}
.chat-container .chat-footer .input-box {
  display: flex;
  align-items: center;
}
.chat-container .chat-footer .input-box .message-input {
  flex: 1;
  height: 72rpx;
  background-color: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}
.chat-container .chat-footer .input-box .send-btn {
  margin-left: 20rpx;
  width: 120rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background-color: #cccccc;
  color: #ffffff;
  border-radius: 36rpx;
  font-size: 28rpx;
}
.chat-container .chat-footer .input-box .send-btn.active {
  background-color: #07c160;
}